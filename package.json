{
  "name": "netxjs-monorepo",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "bunx --bun ultracite fix",
    "check": "bunx --bun ultracite check",
    "fix": "bunx --bun ultracite fix",
    "prepare": "husky && effect-language-service patch",
    "upgrade": "bun run scripts/upgrade.ts",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:generate": "bun run --cwd packages/db db:generate",
    "db:migrate": "bun run --cwd packages/db db:migrate",
    "db:push": "bun run --cwd packages/db db:push",
    "db:studio": "bun run --cwd packages/db db:studio"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.0",
    "@effect/language-service": "^0.83.1",
    "@types/bun": "^1.3.11",
    "@workspace/typescript-config": "workspace:*",
    "bun-types": "^1.3.11",
    "dotenv-cli": "^11.0.0",
    "husky": "^9.1.7",
    "turbo": "^2.8.20",
    "typescript": "5.9.3",
    "ultracite": "7.2.3"
  },
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "catalog": {
    "effect": "^3.21.0",
    "@effect/platform": "^0.96.0"
  }
}
