{
  "name": "@workspace/ai",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "bunx --bun ultracite check",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env.local --",
    "test": "dotenv -e ../../.env.local -- vitest run",
    "test:watch": "dotenv -e ../../.env.local -- vitest"
  },
  "exports": {
    "./adapters/*": "./src/adapters/*.ts",
    "./clients/*": "./src/clients/*.ts",
    "./config": "./src/config/ai-config.ts",
    "./layers": "./src/layers.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.53",
    "@workspace/core": "workspace:*",
    "ai": "^6.0.138",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/vitest": "^0.29.0",
    "@workspace/typescript-config": "workspace:*",
    "typescript": "^5.9.3",
    "vitest": "^3.2.0"
  }
}
